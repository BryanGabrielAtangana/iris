{
  "name": "@iris-sylvia/adapters",
  "version": "0.2.1",
  "description": "Iris surface adapters — write skills and the Tier-1 index into agent surfaces (Claude Code, Codex, …).",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@iris-sylvia/core": "workspace:*",
    "@iris-sylvia/protocol": "workspace:*"
  },
  "keywords": [
    "iris",
    "adapters",
    "claude-code",
    "codex",
    "cursor",
    "skills"
  ],
  "author": "The Iris Authors",
  "homepage": "https://github.com/BryanGabrielAtangana/iris#readme",
  "bugs": "https://github.com/BryanGabrielAtangana/iris/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BryanGabrielAtangana/iris.git",
    "directory": "packages/adapters"
  },
  "publishConfig": {
    "access": "public"
  }
}
