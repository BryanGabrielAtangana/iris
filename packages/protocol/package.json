{
  "name": "@iris/protocol",
  "version": "0.1.0",
  "description": "Iris Skill Access Protocol — zod schemas + generated JSON Schema. Zero runtime deps beyond zod.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "zod": "^3.25.0",
    "zod-to-json-schema": "^3.25.0"
  },
  "keywords": [
    "iris",
    "skills",
    "agents",
    "mcp",
    "zod",
    "schema",
    "protocol"
  ],
  "author": "The Iris Authors",
  "homepage": "https://github.com/BryanGabrielAtangana/iris#readme",
  "bugs": "https://github.com/BryanGabrielAtangana/iris/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BryanGabrielAtangana/iris.git",
    "directory": "packages/protocol"
  },
  "publishConfig": {
    "access": "public"
  }
}
