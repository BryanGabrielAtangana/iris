{
  "name": "@iris/mcp",
  "version": "0.1.0",
  "description": "Iris MCP server — exposes Tier-1 awareness, Tier-2 find, Tier-3 load, resources and prompts over the Model Context Protocol.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "iris-mcp": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@iris/core": "workspace:*",
    "@iris/protocol": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  },
  "keywords": [
    "iris",
    "mcp",
    "model-context-protocol",
    "skills",
    "agents",
    "cursor",
    "claude"
  ],
  "author": "The Iris Authors",
  "homepage": "https://github.com/BryanGabrielAtangana/iris#readme",
  "bugs": "https://github.com/BryanGabrielAtangana/iris/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BryanGabrielAtangana/iris.git",
    "directory": "packages/mcp-server"
  },
  "publishConfig": {
    "access": "public"
  }
}
