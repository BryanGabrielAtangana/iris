{
  "name": "iris-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Iris — an open protocol + reference implementation for reliable agent skill discovery and invocation.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "iris": "node packages/cli/dist/index.js"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.39.0",
    "@types/node": "^22.19.0",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.8.0",
    "tsup": "^8.5.0",
    "tsx": "^4.22.0",
    "turbo": "^2.9.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.0"
  }
}
